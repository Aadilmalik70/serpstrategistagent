# SERP Strategists - Backend Configuration

# Runtime
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
SCHEDULER_ENABLED=false

# Database and cache
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/serpstrategist
REDIS_URL=redis://localhost:6379/0

# Auth and secret protection - use random values of at least 32 characters outside development
SECRET_KEY=change-me-in-production
OAUTH_BRIDGE_SECRET=replace-with-the-same-value-used-by-the-web-service
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-dedicated-random-32-character-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Incremental Google data authorization - server-only values
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
GOOGLE_INTEGRATION_REDIRECT_URI=http://localhost:8000/integrations/google/callback
GOOGLE_INTEGRATION_TIMEOUT_SECONDS=20

# Platform-managed AI gateway - Railway/server secrets only, never workspace credentials
AI_GATEWAY_BASE_URL=https://api.17.wtf/v1
AI_GATEWAY_API_KEY=
AI_PRIMARY_MODEL=posiden/deepseek-v4-flash
AI_REASONING_MODEL=zeus/claude-sonnet-4-6
AI_FALLBACK_MODEL=latina/gpt-5.6-terra
AI_SECONDARY_FALLBACK_MODEL=latina/gpt-5.6-luna
AI_GATEWAY_TIMEOUT_SECONDS=30

# Platform-managed live SERP data - Railway/server secret only
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_TIMEOUT_SECONDS=20

# Stripe billing - Railway/server secrets only
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_TIMEOUT_SECONDS=20

# Authoritative first-party crawler
CRAWLER_USER_AGENT=SERPStrategistsBot/1.0 (+https://serpstrategists.com/bot)
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_CONNECT_TIMEOUT_SECONDS=6
CRAWLER_CONCURRENCY=4
CRAWLER_REQUEST_DELAY_MS=150
CRAWLER_MAX_RESPONSE_BYTES=2000000
CRAWLER_MAX_REDIRECTS=5
CRAWLER_SITEMAP_LIMIT=10

# LibreCrawl is optional enrichment only and should remain disabled on Railway
# unless a separately deployed LibreCrawl service is reachable from the API.
LIBRECRAWL_ENABLED=false
LIBRECRAWL_HOST=127.0.0.1
LIBRECRAWL_PORT=5080
LIBRECRAWL_MCP_PORT=5081

# Durable governed execution. Enable only on the worker service.
EXECUTION_WORKER_ENABLED=false
EXECUTION_WORKER_POLL_SECONDS=5
EXECUTION_WORKER_BATCH_SIZE=5
EXECUTION_JOB_LEASE_SECONDS=120
EXECUTION_JOB_MAX_ATTEMPTS=3
EXECUTION_RETRY_BASE_SECONDS=5
EXECUTION_QUEUE_KEY=serp:execution:ready

# Legacy development-only WordPress values. Production connections belong in the encrypted vault UI.
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=
