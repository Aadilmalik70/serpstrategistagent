# SERP Strategists - Backend Configuration

# Runtime
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
SCHEDULER_ENABLED=false

# Database and cache
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/serpstrategist
REDIS_URL=redis://localhost:6379/0

# Auth - use random values of at least 32 characters outside development
SECRET_KEY=change-me-in-production
OAUTH_BRIDGE_SECRET=replace-with-the-same-value-used-by-the-web-service
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Search providers
SERPAPI_API_KEY=
SERPER_API_KEY=

# Legacy crawler adapter (disabled while first-party crawler is built)
LIBRECRAWL_ENABLED=false
LIBRECRAWL_HOST=127.0.0.1
LIBRECRAWL_PORT=5080
LIBRECRAWL_MCP_PORT=5081

# Optional WordPress development connection
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=
