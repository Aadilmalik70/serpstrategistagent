# Browser-facing FastAPI URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-value

# Shared only between the web service and API. Use the exact same random 32+ character value.
OAUTH_BRIDGE_SECRET=replace-with-a-random-32-character-value

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=
